@model List<ResultOrderingByUserIdDto>
@{
    ViewData["Title"] = "MyOrderList";
    Layout = "~/Areas/User/Views/UserLayout/Index.cshtml";
    int count = 0;
    // Renk skalasını diziye aldık, böylece 7'den fazla kayıt gelirse başa döner.
    string[] tableColors = { "table-info", "table-warning", "table-danger", "table-success", "table-primary", "table-secondary" };
}

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Sipariş Geçmişim</h4>
                        <div class="table-responsive pt-3">
                            <table class="table table-bordered table-hover">
                                <thead class="thead-dark">
                                    <tr>
                                        <th>#</th>
                                        <th>Toplam Fiyat</th>
                                        <th>Sipariş Tarihi</th>
                                        <th>İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        // Mod (%) operatörü ile renkler dizi içinde döngüye girer
                                        var rowColor = tableColors[count % tableColors.Length];
                                        count++;

                                        <tr class="@rowColor">
                                            <th scope="row">@count</th>
                                            <td>@item.TotalPrice.ToString("C2")</td>
                                            <td>@(((DateTime)item.OrderDate).ToString("dd MMMM yyyy"))</td>
                                            <td>
                                                <a href="/Order/OrderDetail/@item.OrderingId" class="btn btn-outline-dark btn-sm">
                                                    <i class="mdi mdi-eye"></i> Sipariş Detayları
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>